# Copy this file's contents into Vercel's Environment Variables settings.
# Never commit real values here — this file only documents what's needed.
#
# Both of these come from Supabase's "Connect to your project" dialog
# (click the "Connect" button on your project dashboard).

# The "Project URL" row
SUPABASE_URL=https://your-project-ref.supabase.co

# The "SUPABASE_SECRET_KEY" row (starts with sb_secret_...) — click the eye
# icon to reveal it before copying. This bypasses Row Level Security, so it
# must only ever be set as a server-side environment variable (Vercel),
# never exposed in frontend code.
SUPABASE_SECRET_KEY=sb_secret_your-key-here
